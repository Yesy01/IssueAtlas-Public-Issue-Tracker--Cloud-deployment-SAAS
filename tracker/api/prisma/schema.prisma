datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  user
  admin
}

enum IssueStatus {
  new
  triaged
  in_progress
  resolved
}

enum IssueType {
  pothole
  streetlight
  drainage
  other
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  role           Role            @default(user)
  createdAt      DateTime        @default(now())
  issues         Issue[]
  comments       Comment[]
  upvotes        IssueUpvote[]
  notifications  Notification[]
  passwordResets PasswordReset[]
  verifiedIssues Issue[]         @relation("VerifiedBy")
}

model Issue {
  id         String @id @default(cuid())
  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])

  title       String
  description String

  status IssueStatus @default(new)
  type   IssueType

  lat      Float
  lon      Float
  location Unsupported("geometry(Point, 4326)")?

  imageUrl String?
  address  String?
  areaName String?

  adminResponse       String?
  adminRespondedAt    DateTime?
  officialResponse    String?
  officialRespondedAt DateTime?
  verified            Boolean   @default(false)
  verifiedAt          DateTime?
  verifiedById        String?
  flagged             Boolean   @default(false)
  flaggedReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verifiedBy    User?           @relation("VerifiedBy", fields: [verifiedById], references: [id])
  history       StatusHistory[]
  comments      Comment[]
  upvotes       IssueUpvote[]
  notifications Notification[]

  @@index([location], type: Gist)
}

model Comment {
  id String @id @default(cuid())

  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  body      String
  createdAt DateTime @default(now())
}

model IssueUpvote {
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@id([issueId, userId])
}

model StatusHistory {
  id        String       @id @default(cuid())
  issue     Issue        @relation(fields: [issueId], references: [id])
  issueId   String
  oldStatus IssueStatus?
  newStatus IssueStatus
  changedBy String
  changedAt DateTime     @default(now())
}

enum NotificationType {
  STATUS_CHANGE
  COMMENT
  // You can add more later if you want
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  issue     Issue            @relation(fields: [issueId], references: [id])
  issueId   String
  type      NotificationType
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
}

model PasswordReset {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId, used])
}
